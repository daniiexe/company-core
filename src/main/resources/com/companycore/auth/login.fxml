<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="600.0" prefWidth="900.0" fx:id="loginWindow" xmlns="http://javafx.com/javafx/17.0.2" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@style/style.css">
    <children>

        <Pane opacity="0.2" />

        <VBox fx:id="loginContent" alignment="CENTER" maxWidth="400.0" maxHeight="500.0" spacing="20.0">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <children>
                <Label fx:id="lbLogo" text="Company Core">
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Label>

                <VBox fx:id="loginContentForm" alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label fx:id="lbLogin" text="Login"/>

                        <Label fx:id="lbEmail" text="Email" />
                        <TextField fx:id="tfEmail" promptText="username@gmail.com" />

                        <Label fx:id="lbPassword" text="Password" />
                        <PasswordField fx:id="pfPassword" promptText="Password" />

                        <Hyperlink fx:id="hlForgotPassword" text="Forgot Password?"/>

                        <Button fx:id="btnLogin" text="Log in" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>